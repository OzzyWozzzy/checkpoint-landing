{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/personas/**",
              "components/surfaces/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|loading|iconLeft|iconRight|fullWidth|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, loading, iconLeft, iconRight, fullWidth, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|title|meta|actions|footer|padded|interactive|accent|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, title, meta, actions, footer, padded, interactive, accent, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|indeterminate|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, disabled, indeterminate, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|header|width|align|mono|render|sortValue|sortable|key|ref|className|style|children)$/]",
        "message": "<DataColumn> doesn't accept that prop. Declared props: key, header, width, align, mono, render, sortValue, sortable."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right|center)$/]",
        "message": "<DataColumn> align must be one of 'left' | 'right' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|label|variant|size|active|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, label, variant, size, active, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|solid)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|invalid|iconLeft|addonRight|mono|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, invalid, iconLeft, addonRight, mono, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PersonaGlyph'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|size|color|framed|style|key|ref|className|style|children)$/]",
        "message": "<PersonaGlyph> doesn't accept that prop. Declared props: type, size, color, framed, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|level|height|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, level, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:accent|healthy|warning|critical|info)$/]",
        "message": "<ProgressBar> level must be one of 'accent' | 'healthy' | 'warning' | 'critical' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|options|size|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedControl> doesn't accept that prop. Declared props: value, onChange, options, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<SegmentedControl> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|options|disabled|id|style|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, value, onChange, options, disabled, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SeverityBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|children|count|dot|style|key|ref|className|style|children)$/]",
        "message": "<SeverityBadge> doesn't accept that prop. Declared props: level, children, count, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SeverityBadge'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:critical|warning|healthy|info|neutral)$/]",
        "message": "<SeverityBadge> level must be one of 'critical' | 'warning' | 'healthy' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|children|action|icon|onClose|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: tone, title, children, action, icon, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|healthy|warning|critical)$/]",
        "message": "<Toast> tone must be one of 'info' | 'healthy' | 'warning' | 'critical'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
